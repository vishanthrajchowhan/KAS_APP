# Flask
SECRET_KEY=replace-with-a-long-random-secret

# Supabase PostgreSQL
DATABASE_URL=postgresql://username:password@your-supabase-host:6543/postgres

# Supabase Storage
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-service-role-or-storage-capable-key

# Optional pool tuning for low-cost deployments
DB_POOL_MIN_SIZE=1
DB_POOL_MAX_SIZE=5
